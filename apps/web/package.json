{
  "name": "@woktool/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "build:cf": "next build && npx opennextjs-cloudflare build --skipNextBuild",
    "deploy": "npm run build:cf && wrangler pages deploy .open-next/assets --project-name woktool --branch main --commit-dirty=true",
    "preview": "npm run build:cf && wrangler pages dev .open-next/assets"
  },
  "dependencies": {
    "@imgly/background-removal": "^1.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "color-thief-browser": "^2.0.2",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.3",
    "gifenc": "^1.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "marked": "^17.0.3",
    "next": "14.2.35",
    "p-limit": "^3.1.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "18.3.1",
    "react-dropzone": "^15.0.0",
    "react-intersection-observer": "^10.0.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "2.3.0",
    "tldraw": "^4.4.0",
    "zod": "^3.25.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@types/node": "20.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.15",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.4",
    "typescript": "5.4.5",
    "wrangler": "^4.69.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0"
  }
