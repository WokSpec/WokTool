unded-[1.5rem] p-6 transition-all duration-500 hover:border-white/[0.15] hover:shadow-[0_0_40px_rgba(255,255,255,0.01)] \"><div class=\"absolute inset-0 rounded-[1.5rem] bg-gradient-to-br from-white/[0.02] to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none\"></div><div class=\"relative mb-6\"><h3 class=\"text-sm font-black uppercase tracking-[0.2em] text-zinc-500 mb-1.5\">Describe your Image</h3><p class=\"text-[13px] text-zinc-600 font-medium leading-relaxed\">Include specific text in double quotes for best results.</p></div><div class=\"relative\"><div class=\"space-y-6\"><div class=\"w-full\"><textarea class=\"\n            block w-full rounded-2xl bg-white/[0.03] border text-white placeholder-zinc-700 \n            focus:outline-none focus:ring-2 focus:ring-white/10 focus:bg-white/[0.05] transition-all duration-300\n            border-white/[0.08] hover:border-white/[0.15]\n            px-5 py-4 text-[14px] font-medium min-h-[140px] resize-y custom-scrollbar\n            min-h-[120px] text-base\n          \" placeholder=\"e.g. A movie poster for &quot;THE LAST VOYAGE&quot; with a futuristic ship in space\"></textarea></div><div class=\"grid grid-cols-2 gap-4\"><div class=\"w-full\"><label class=\"block text-[11px] font-black uppercase tracking-[0.2em] text-zinc-500 mb-2 ml-1\">Aspect Ratio</label><div class=\"relative group\"><select class=\"\n              block w-full rounded-xl bg-white/[0.03] border text-white appearance-none cursor-pointer\n              focus:outline-none focus:ring-2 focus:ring-white/10 focus:bg-white/[0.05] transition-all duration-300\n              border-white/[0.08] hover:border-white/[0.15]\n              pl-4 pr-10 py-3 text-[14px] font-medium\n              \n            \"><option value=\"ASPECT_1_1\" class=\"bg-zinc-900 text-white\" selected=\"\">1:1 Square</option><option value=\"ASPECT_16_9\" class=\"bg-zinc-900 text-white\">16:9 Wide</option><option value=\"ASPECT_9_16\" class=\"bg-zinc-900 text-white\">9:16 Portrait</option><option value=\"ASPECT_4_3\" class=\"bg-zinc-900 text-white\">4:3</option><option value=\"ASPECT_3_2\" class=\"bg-zinc-900 text-white\">3:2</option></select><div class=\"absolute inset-y-0 right-0 flex items-center px-3 pointer-events-none text-zinc-600 group-hover:text-zinc-400 transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></div></div></div><div class=\"w-full\"><label class=\"block text-[11px] font-black uppercase tracking-[0.2em] text-zinc-500 mb-2 ml-1\">Style Preset</label><div class=\"relative group\"><select class=\"\n              block w-full rounded-xl bg-white/[0.03] border text-white appearance-none cursor-pointer\n              focus:outline-none focus:ring-2 focus:ring-white/10 focus:bg-white/[0.05] transition-all duration-300\n              border-white/[0.08] hover:border-white/[0.15]\n              pl-4 pr-10 py-3 text-[14px] font-medium\n              \n            \"><option value=\"AUTO\" class=\"bg-zinc-900 text-white\" selected=\"\">Auto</option><option value=\"GENERAL\" class=\"bg-zinc-900 text-white\">General</option><option value=\"REALISTIC\" class=\"bg-zinc-900 text-white\">Realistic</option><option value=\"DESIGN\" class=\"bg-zinc-900 text-white\">Design</option><option value=\"RENDER_3D\" class=\"bg-zinc-900 text-white\">3D Render</option><option value=\"ANIME\" class=\"bg-zinc-900 text-white\">Anime</option></select><div class=\"absolute inset-y-0 right-0 flex items-center px-3 pointer-events-none text-zinc-600 group-hover:text-zinc-400 transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-line